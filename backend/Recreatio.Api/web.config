<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <aspNetCore
      processPath="dotnet"
      arguments=".\Recreatio.Api.dll"
      stdoutLogEnabled="true"
      stdoutLogFile=".\logs\stdout"
      hostingModel="inprocess">
      <environmentVariables>
        <environmentVariable name="DataProtection__RequireCertificateOutsideDevelopment" value="false" />
      </environmentVariables>
    </aspNetCore>
  </system.webServer>
</configuration>
