{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=Recreatio;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Auth": {
    "RequireEmailConfirmation": false,
    "MaxFailedLoginAttempts": 5,
    "LockoutMinutes": 15,
    "SessionIdleMinutes": 60,
    "RememberMeDays": 30,
    "CookieDomain": "",
    "CookieSameSite": "None",
    "CookieSecurePolicy": "Always"
  },
  "Csrf": {
    "CookieDomain": "",
    "CookieSameSite": "None",
    "CookieSecurePolicy": "Always"
  },
  "Crypto": {
    "ServerMasterSalt": "REPLACE_WITH_BASE64_SALT",
    "MasterKeyIterations": 600000,
    "MasterKeyLengthBytes": 32,
    "SharedViewIterations": 200000,
    "SharedViewKeyLengthBytes": 32
  },
  "DataProtection": {
    "CertificatePath": "",
    "CertificatePassword": "",
    "CertificateThumbprint": "",
    "RequireCertificateOutsideDevelopment": false
  },
  "BlobStorage": {
    "RootPath": "secure-file-store",
    "ChunkSizeBytes": 65536,
    "MaxUploadBytes": 52428800
  },
  "Calendar": {
    "ReminderPollSeconds": 60,
    "ReminderLookbackMinutes": 5,
    "ReminderLookaheadMinutes": 60,
    "ReminderBatchSize": 250,
    "WebhookSigningSecret": ""
  }
}
